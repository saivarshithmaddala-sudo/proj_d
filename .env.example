# Environment variables for Zamazon Identity Engine

# Connection string for the Neon or Supabase PostgreSQL database
DATABASE_URL="postgresql://<user>:<password>@<host>/neondb?sslmode=require&schema=zamazon_identity_dev"

# Connection string for the test database schema (disposable test database)
DATABASE_URL_TEST="postgresql://<user>:<password>@<host>/neondb?sslmode=require&schema=zamazon_identity_test"
